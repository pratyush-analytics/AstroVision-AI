# .env.example
# =====================================================
# AstroVision AI — Environment Variable Reference
# =====================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =====================================================

# ── AI / LLM PROVIDER ──────────────────────────────
# OpenAI API key for live horoscope and prediction generation
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic Claude API key (alternative AI provider)
ANTHROPIC_API_KEY=your_anthropic_key_here

# Google Gemini API key (alternative AI provider)
GEMINI_API_KEY=your_gemini_api_key_here

# ── ASTROLOGY APIs ─────────────────────────────────
# AstroAPI.com or similar for real planetary positions
ASTRO_API_KEY=your_astro_api_key_here
ASTRO_API_BASE_URL=https://api.astroapi.com/v1

# Swiss Ephemeris API for accurate Vedic chart calculations
SWISS_EPHEM_API_KEY=your_swiss_ephem_key_here

# ── APP CONFIGURATION ──────────────────────────────
# Application environment: development | staging | production
NODE_ENV=development

# Application base URL (for sharing links, SEO)
APP_BASE_URL=https://astrovision-ai.netlify.app

# App version (matches package.json)
APP_VERSION=1.0.0

# ── ANALYTICS (OPTIONAL) ───────────────────────────
# Google Analytics 4 Measurement ID
GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Plausible Analytics domain (privacy-first alternative)
PLAUSIBLE_DOMAIN=astrovision-ai.com

# ── ERROR MONITORING (OPTIONAL) ────────────────────
# Sentry DSN for error tracking
SENTRY_DSN=https://xxx@sentry.io/xxx

# ── FEATURE FLAGS ──────────────────────────────────
# Enable live AI readings (requires OPENAI_API_KEY)
ENABLE_LIVE_AI=false

# Enable real planetary positions (requires ASTRO_API_KEY)
ENABLE_REAL_EPHEMERIS=false

# Enable user accounts
ENABLE_AUTH=false

# ── RATE LIMITING (IF BACKEND ADDED) ───────────────
# Max API calls per IP per hour
RATE_LIMIT_PER_HOUR=100

# ── CONTACT / SUPPORT ──────────────────────────────
SUPPORT_EMAIL=support@astrovision-ai.com
